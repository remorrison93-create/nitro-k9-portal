# --- Database ---
# Real Postgres connection string (Supabase / Neon / Railway / RDS, etc).
# `prisma generate` and `npm run dev` both work without a real one, but any page that
# queries the DB will error until this points at a live instance.
DATABASE_URL="postgresql://user:password@localhost:5432/nitro_k9"

# --- Auth ---
# Generate with: npx auth secret
AUTH_SECRET="replace-with-a-random-32-byte-secret"

# --- Square (payments, and however contract-signed status ends up reaching us — see the
# note at the top of src/lib/integrations/square.ts) ---
SQUARE_ACCESS_TOKEN=""
SQUARE_LOCATION_ID=""
SQUARE_WEBHOOK_SIGNATURE_KEY=""

# --- Microsoft Graph (Outlook calendar) ---
MS_GRAPH_TENANT_ID=""
MS_GRAPH_CLIENT_ID=""
MS_GRAPH_CLIENT_SECRET=""
MS_GRAPH_CALENDAR_USER="" # the mailbox/UPN whose calendar is the source of truth

# --- Email ---
EMAIL_PROVIDER_API_KEY=""
